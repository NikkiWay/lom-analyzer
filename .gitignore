# Gradle
.gradle/
build/

# Kotlin
*.class
*.jar
*.war
*.ear

# The Gradle wrapper JAR must be version-controlled: without it `./gradlew`
# cannot bootstrap on a fresh clone (and CI fails). Re-included after *.jar.
!gradle/wrapper/gradle-wrapper.jar

# IDEA
.idea/
*.iml
*.ipr
*.iws
out/

# Python venv
venv/
.venv/
__pycache__/
*.pyc

# Application artifacts
.app_lock
logs/
app_data/

# Downloaded ML model weights (HuggingFace cache, ~115 MB; fetched at first run)
models/

# Scratch Gradle experiment, not part of the build
sample-search/

# OS files
.DS_Store
Thumbs.db

# Environment / secrets
.env
*.key

# Служебные файлы компилятора Kotlin (логи падений, кэш сборки)
.kotlin/
