# Нормализация окончаний строк. Проект разрабатывается на Windows, а CI собирает
# его на Linux (ubuntu-latest), поэтому расхождение окончаний строк ломает сборку
# не там, где его вносят.
#
# В репозитории всё текстовое хранится с LF; в рабочую копию Git подставляет
# окончания, принятые в системе разработчика.
* text=auto

# Файлы, которые обязаны остаться с LF независимо от системы: их исполняет
# оболочка Linux, и CR в конце строки превращает shebang в «/bin/sh\r» — такого
# интерпретатора нет.
gradlew         text eol=lf
*.sh            text eol=lf

# Скрипт для cmd.exe: только CRLF.
gradlew.bat     text eol=crlf

# Двоичные файлы не трогать (иначе нормализация их испортит).
*.jar           binary
*.png           binary
*.jpg           binary
*.pdf           binary
*.xlsx          binary
*.docx          binary
*.gz            binary
